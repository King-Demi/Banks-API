{
   "lace_env":"local",
   "lace_config":"config_local",
   "brand_name":"lacePHP",
   "routing":{
      "auto_discover":true,
      "route_paths":[
         "routes/api"
      ]
   },
   "views_path":"shoebox/views",
   "errors":{
      "show_debug":true,
      "templates":{
         "404":"shoebox/views/errors/404.html",
         "500":"shoebox/views/errors/500.html"
      }
   },
   "metrics":{
      "enabled": false
   },
   "paths":{
      "vendor":"vendor"
   },
   "cli":{
      "allow_composer":false,
      "ai_enabled":false
   },
   "plugins":{
      "auto_discover_folder":true,
      "auto_discover_composer":false
   },
   "graphql":{
      "enabled":false,
      "endpoint":"graphql",
      "schemaClass":"Weave\\GraphQL\\Schema"
   },
   "cache":{
      "enabled":false,
      "path":"shoebox/cache/responses"
   },
   "ip":{
      "whitelist":[

      ],
      "blacklist":[

      ],
      "routes":{

      }
   },
   "endpoints":{
      "docs":"lace/docs",
      "health":"lace/health",
      "dashboard":"lace/dashboard",
      "metrics":"lace/metrics",
      "migrations": "lace/migrate",
      "guarded": false
   }
}